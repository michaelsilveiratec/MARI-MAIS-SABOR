# Copie este arquivo para .env.print-agent e substitua a URL abaixo.
# Use a mesma DATABASE_URL configurada na Vercel.
DATABASE_URL=postgresql://USUARIO:SENHA@HOST/neondb?sslmode=require

# AUTO detecta a impressora térmica conectada ao USB. O nome também pode ser definido pelo painel Admin.
PRINTER_NAME=AUTO

# Intervalo entre consultas ao Neon. Cinco segundos é suficiente para a cozinha.
POLL_INTERVAL_MS=5000

# Use true apenas para testar sem gastar papel. Nesse modo o pedido não é marcado como impresso.
PRINT_AGENT_DRY_RUN=false
